tentstack/0311260315/slick.min.js"></script><script id="digital-data">(function () {
    var BRANDS = [{"code":"EV","name":"Eddie Vs","hosts":["www.eddiev.com","eddiev.com","m.eddiev.com","ev.localhost","dev1-ev.olivegarden.com","stage1.eddiev.com","test1-ev.olivegarden.com","beta.eddiev.com"],"pathPrefix":"/ev"},{"code":"CG","name":"The Capital Grille","hosts":["www.thecapitalgrille.com","thecapitalgrille.com","m.thecapitalgrille.com","tcg.localhost","dev1-tcg.olivegarden.com","stage1.thecapitalgrille.com","test1-tcg.olivegarden.com","beta.thecapitalgrille.com"],"pathPrefix":"/tcg"},{"code":"CB","name":"The Capital Burger","hosts":["www.thecapitalburger.com","thecapitalburger.com","m.thecapitalburger.com","tcb.localhost","dev1-tcb.olivegarden.com","stage1.thecapitalburger.com","test1-tcb.olivegarden.com","beta.thecapitalburger.com"],"pathPrefix":"/tcb"},{"code":"RC","name":"Ruths Chris","hosts":["www.ruthschris.com","ruthschris.com","m.ruthschris.com","rc.localhost","dev1-rc.olivegarden.com","stage1.ruthschris.com","test1-rc.olivegarden.com","beta.ruthschris.com"],"pathPrefix":"/rc"},{"code":"CH","name":"Chuys","hosts":["www.chuys.com","chuys.com","m.chuys.com","ch.localhost","dev1-ch.olivegarden.com","stage1.chuys.com","test1-ch.olivegarden.com","beta.chuys.com"],"pathPrefix":"/ch"},{"code":"S52","name":"Seasons 52","hosts":["www.seasons52.com","seasons52.com","m.seasons52.com","s52.localhost","dev1-s52.olivegarden.com","stage1.seasons52.com","test1-s52.olivegarden.com","beta.seasons52.com"],"pathPrefix":"/stg"},{"code":"YH","name":"Yard House","hosts":["www.yardhouse.com","yardhouse.com","m.yardhouse.com","yh.localhost","dev1-yh.olivegarden.com","stage1.yardhouse.com","test1-yh.olivegarden.com","beta.yardhouse.com"],"pathPrefix":"/yh"},{"code":"LH","name":"LongHorn","hosts":["www.longhornsteakhouse.com","longhornsteakhouse.com","m.longhornsteakhouse.com","lh.localhost","dev1-lh.olivegarden.com","stage1.longhornsteakhouse.com","test1-lh.olivegarden.com","beta.longhornsteakhouse.com"],"pathPrefix":"/lh"},{"code":"CS","name":"Cheddars Site","hosts":["www.cheddars.com","cheddars.com","m.cheddars.com","csk.localhost","dev1-csk.olivegarden.com","stage1.cheddars.com","test1-csk.olivegarden.com","beta.cheddars.com"],"pathPrefix":"/cs"},{"code":"BB","name":"Bahama Breeze","hosts":["www.bahamabreeze.com","bahamabreeze.com","m.bahamabreeze.com","bb.localhost","dev1-bb.olivegarden.com","stage1.bahamabreeze.com","test1-bb.olivegarden.com","beta.bahamabreeze.com"],"pathPrefix":"/bb"},{"code":"OG","name":"Olive Garden","hosts":["www.olivegarden.com","olivegarden.com","m.olivegarden.com","og.localhost","dev1-cdn.olivegarden.com","stage1.olivegarden.com","test1-cdn.olivegarden.com/","beta.olivegarden.com"],"pathPrefix":"/og"}];
    var host = (typeof location !== 'undefined' && location.hostname) ? location.hostname.toLowerCase() : '';
    var path = (typeof location !== 'undefined' && location.pathname) ? location.pathname : '/';

    function applyMobileBrand(brand) {
      if (host.includes('m.')) {
        return Object.assign({}, brand, { name: brand.name + " Mobile" });
        SITE_TYPE = "MOBILE";
      }
      return brand;
    }

    function pickBrand() {
      // 1) host match
      for (var i = 0; i < BRANDS.length; i++) {
        var b = BRANDS[i];
        var matchHost = b.hosts.some(x => x.toLowerCase() === host);
        if (matchHost) {
            let brandName =  applyMobileBrand(b);
            return { name: brandName.name, code: b.code };
        }
    }
    return { name: 'Empty', code: 'Empty' };
    }

    function getPageType(p) {
      if (p === '/' || p === '/home') return 'Home';
      if (/\/menu(\/|$)/i.test(p)) return 'Menu';
      if (/\/(locations?|stores?)(\/|$)/i.test(p)) return 'Location';
      if (/(checkout|payment)/i.test(p)) return 'Checkout';
      if (/(reservation|book)/i.test(p)) return 'Reservation';
      if (/(cart|order)/i.test(p)) return 'Cart';
      return "Static";
    }

    function readCookie(name) {
      if (typeof document === 'undefined') return null;
      var nameEQ = name + "=";
      var ca = document.cookie ? document.cookie.split(';') : [];
      for (var i = 0; i < ca.length; i++) {
        var c = ca[i].trim();
        if (c.indexOf(nameEQ) === 0) return decodeURIComponent(c.substring(nameEQ.length));
      }
      return null;
    }

    function parseDriRest(cookieVal) {
      try {
        var parts = cookieVal.split('@@');
        if (parts.length > 11) {
          return {
            locationId: parts[11] || null,
            locationRID: parts[11] || null,
            locationName: null,
            locationState: null,
            locationZip: null
          };
        }
      } catch (e) {}
      return null;
    }

    var brand = pickBrand();
    var pageType = getPageType(path);

    var digitalData = {
      location: {
        locationInfo: {
          locationId: null,
          locationName: null,
          locationRID: null,
          locationState: null,
          locationZip: null
        }
      },
      page: {
        pageInfo: {
          siteName: brand.name || '',
          siteBrand: brand.code || '',
          siteType: "WEB",
          language: "en_US",
          sysEnv: "Prod",
          geoCountry: "US",
          destinationURL: path,
          pageName: path,
          cacheable: false
        },
        category: {
          pageType: pageType,
          primaryCategory: pageType.toLowerCase()
        }
      },
      user: {
        profile: {
          profileInfo: {
            profileType: "guest",
            loginStatus: "logged-out",
            profileID: null
          }
        }
      },
      cart: { item: [], price: {}, attributes: {} },
      event: []
    };

    var dri = readCookie("DRIREST");
    if (dri) {
      var parsed = parseDriRest(dri);
      if (parsed) {
        digitalData.location.locationInfo = Object.assign({}, digitalData.location.locationInfo, parsed);
      }
    }

    window.digitalData = digitalData;
  })();</script><link rel="stylesheet" href="https://media.olivegarden.com/css/cms/contentstack/0311260315/bootstrap-4.6.2-dist/dist/css/bootstrap.min.css"/><link rel="stylesheet" href="https://media.olivegarden.com/css/cms/contentstack/0311260315/slick/slick.css"/><link rel="stylesheet" href="https://media.olivegarden.com/css/cms/contentstack/0311260315/slick/slick-theme.css"/><link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css"/><link rel="stylesheet" href="/cmsdata/olivegarden/css/core.css"/><input type="hidden" id="ljvmname" name="localjvmname"/><input type="hidden" id="dtmenabled" value="true"/><input type="hidden" id="locationURL" value="/locations"/><input type="hidden" id="conceptCode"/><input type="hidden" id="currentLocale" value="en_US"/><input type="hidden" id="sessionOrderType" value=""/><input type="hidden" id="pdRestId" value=""/><input type="hidden" id="orderTypeValue" value="0"/><input type="hidden" id="language" value="en"/><input type="hidden" id="country" value="US"/><input type="hidden" id="channel" value="WEB"/><input type="hidden" id="EMTemplateName" name="EMTemplateName" value="responsive-contentupdate"/><input type="hidden" id="emailSignup" value="/email-signup"/><input type="hidden" id="emailSignupCounter" value="1"/><input type="hidden" id="emailSignUpInterstitialOverlayUrl" value="/email-signup-loyalty"/><input type="hidden" id="overlayHeaderEnabled" value="false"/><input type="hidden" id="signupSource"/><input type="hidden" id="reservationSignupSource"/><input type="hidden" id="mediaPath"/><input type="hidden" id="showHappyHour" value=""/><input type="hidden" id="emailSignupSessionCounter" value="1"/><input type="hidden" id="emailSignupCookieResetTime" value="183"/><script src="/_nextcms/_next/static/chunks/polyfills-42372ed130431b0a.js" noModule=""></script></head><body><noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PF6WCC5" height="0" width="0" style="display:non