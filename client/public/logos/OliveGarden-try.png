is Neue;--btn-border:2px solid #000000;--btn-hover-border:0;--btn-text-align:Center;--btn-bg-mobile:rgba(0, 0, 0, 0);--btn-color-mobile:#000000;--btn-hover-bg-mobile:#000000;--btn-hover-color-mobile:#ffffff;--btn-font-size-mobile:14px;--btn-font-weight-mobile:700;--btn-font-family-mobile:Neulis Neue;--btn-border-mobile:2px solid #000000;--btn-hover-border-mobile:0;--btn-text-align-mobile:Center;--mobile-line-height:normal;--desktop-line-height:normal" href="/customer-service/join-eclub">SIGN UP</a></div></article><article role="listitem" class="quickaction-card" style="--bg-mobile:url(&quot;https://media.olivegarden.com/images/OG_Redesign_Assets/Mobile/Homepage/Mobile_Homepage_Gift_Cards_Card.png&quot;);--bg-desktop:url(&quot;https://media.olivegarden.com/images/OG_Redesign_Assets/Desktop/Homepage/Desktop_Homepage_Gift_Cards_Card.png&quot;)"><div class="quickaction-content"><div class="quickaction-content-inner"><h2 class="og-typography mb-0" style="--font-mobile:22px;--font-desktop:20px;--weight-mobile:700;--weight-desktop:700;--font-family-mobile:Neulis Cursive;--font-family-desktop:Neulis Cursive;--line-height-mobile:1;--line-height-desktop:1;--color-mobile:#000000;--color-desktop:#000000;--text-align-desktop:Center;--text-align-mobile:Left">Gift Cards</h2></div><a target="_self" class="btn og-button text-nowrap w-fit-content quickaction-card-btn" aria-label="LEARN MORE" data-link-info="LEARN MORE cta" style="--btn-bg:rgba(0, 0, 0, 0);--btn-color:#000000;--btn-hover-bg:#000000;--btn-hover-color:#ffffff;--btn-font-size:16px;--btn-font-weight:700;--btn-font-family:Neulis Neue;--btn-border:2px solid #000000;--btn-hover-border:0;--btn-text-align:Center;--btn-bg-mobile:rgba(0, 0, 0, 0);--btn-color-mobile:#000000;--btn-hover-bg-mobile:#000000;--btn-hover-color-mobile:#ffffff;--btn-font-size-mobile:14px;--btn-font-weight-mobile:700;--btn-font-family-mobile:Neulis Neue;--btn-border-mobile:2px solid #000000;--btn-hover-border-mobile:0;--btn-text-align-mobile:Center;--mobile-line-height:normal;--desktop-line-height:normal" href="/gift-cards">LEARN MORE</a></div></article></div></section><div>
<script>
(function($){

  function initWhenAvailable(){
    const slider = document.querySelector(".specials-slider");

    if (!slider) return;   // Not on home page

    // Prevent double-initialization
    if ($(slider).hasClass("slick-initialized")) return;

    console.log("Initializing Slick (auto-detected Home load)");

    $(slider).slick({
      slidesToShow: 3,
      slidesToScroll: 1,
      infinite: false,
      dots: false,
      arrows: true,
      variableWidth: false,
      centerMode: false,
      prevArrow: `
        <button type="button" class="slick-prev" aria-label="Previous specials">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M16 4L8 12L16 20" stroke="#000" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>`,
      nextArrow: `
        <button type="button" class="slick-next" aria-label="Next specials">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M8 4L16 12L8 20" stroke="#000" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>`,
      responsive: [
        { breakpoint: 1200, settings: { slidesToShow: 3 } },
        { breakpoint: 992,  settings: { slidesToShow: 2 } },
        {
          breakpoint: 768,
          settings: {
            slidesToShow: 1,
            arrows: false,
            dots: true,
            centerMode: false,
            variableWidth: true,
          },
        },
      ],
    });
  }
  
  
  /* -------------------------
       VIDEO ROTATION
    --------------------------*/
    var videoSource = [
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/25560_OGcomREV_Part1.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/25560_OGcomREV_Part2.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/25560_OGcomREV_Part3.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/25560_OGcomREV_Part4.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/25560_OGcomREV_Part5.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/25560_OGcomREV_Part6.mp4",
    ];

    var videoSmallSource = [
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/mobile_OGcomREV_Part1_1.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/mobile_OGcomREV_Part2_1.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/mobile_OGcomREV_Part3_1.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/mobile_OGcomREV_Part4_1.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/mobile_OGcomREV_Part5_1.mp4",
      "https://media.olivegarden.com/images/site/ext/pages/_promotions/video/mobile_OGcomREV_Part6_1.mp4",
    ];

    var videoCount = 0;

    function setVideo() {
      var src =
        window.innerWidth > 640
          ? videoSource[videoCount]
          : videoSmallSource[videoCount];

      const video = $("#home_feature_video");
      video.attr("src", src);
      video[0].addEventListener("ended", nextVideo, false);
    }

    function nextVideo() {
      videoCount = (videoCount + 1) % videoSource.length;
      playVideo(videoCount);
    }

    function playVideo(num) {
      var src =
        window.innerWidth > 640
          ? videoSource[num]
          : videoSmallSource[num];

      const video = $("#home_feature_video");
      video.attr("src", src)[0].load();
      video[0].play();
    }


  // Initial attempt (first page load)
  setTimeout(initWhenAvailable, 1000);
  setTimeout(setVideo, 1000);
  

  // Detect re-render / navigation changes (Next.js DOM replacement)
  const mo = new MutationObserver(() => {
    initWhenAvailable();
  });

  mo.observe(document.body, { childList: true, subtree: true });

})(jQuery);
</script>
