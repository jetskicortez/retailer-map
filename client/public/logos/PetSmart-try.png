003c/strong\u003e Cat\u003cbr /\u003e\u003cstrong\u003eScented/Unscented:\u003c/strong\u003e Unscented\u003cbr /\u003e\u003cstrong\u003eClumping/Non-Clumping:\u003c/strong\u003e Clumping\u003cbr /\u003e\u003cstrong\u003ePackage Weight: \u003c/strong\u003e40 LBS (18.2 kg)\u003c/p\u003e\r\n\u003cp\u003e\u003cstrong\u003eDirections: \u003c/strong\u003eFill litter pan with 3 to 4 inches of cat litter to allow for pawing and covering. For best results, remove solid waste daily. Replace litter completely every 7 to 10 days, or as needed. Clean litter pan with warm water and mild detergent. Rinse and dry the pan completely before refilling it with fresh litter.\u003c/p\u003e\r\n\u003cp\u003e\u003cstrong\u003eCaution:\u003c/strong\u003e A parasite sometimes found in cat feces can cause toxoplasmosis in pregnant women and those with suppressed immune systems. Please wash hands thoroughly after handling used cat litter.\u003c/p\u003e\r\n\u003cp\u003e\u003cstrong\u003eDisposal Warning:\u003c/strong\u003e\u003cbr /\u003eDispose of waste in a trash receptacle. Encouraging your cat to use an indoor litter pan, or properly disposing of outdoor cat feces, is beneficial to overall water quality. Do not flush cat litter in toilets or dispose of it outdoors in gutters or storm drains. Used litter is not recommended for garden use.\u003c/p\u003e\r\n\u003cp\u003e\u003cstrong\u003eTransitioning to ExquisiCat\u0026reg; Litter:\u003c/strong\u003e Some cats may need assistance in adjusting to a new litter. Begin with 1 inch of ExquisiCat\u0026reg; Litter covered with 2 inches of the previous litter product. Do not mix the layers; your cat will do this when pawing and covering. Gradually add less old litter each time you change the litter pan. Most cats will comfortably adjust to the new litter after 3 to 4 changes.\u003c/p\u003e","onlineFrom":1628294400000,"onlineTo":4102444799000,"litter-features":["Advanced Odor Control","Clumping","Low Dust","Multi-Cat","Unscented"],"litter-materials":["Clay"],"litter-types":["Clay"],"customPet":["Cat"],"productAvailabilityLocations":["In Store"],"avalaraTaxCode":"111","bvAverageRating":4.2,"bvReviewCount":757,"conversionRate":100,"customBvAverageRating":4,"manufacturerName":"WYO-BEN PET","manufacturerSku":"EXQ40FF","shipToHome-isCASupported":true,"shoppingOptions-isBopisEligible":true,"shoppingOptions-isInStoreOnly":false,"shoppingOptions-isSoldOnlineOnly":false,"customScheduledDeliveryEligible":true,"isSubscriptionEnabled":true,"isInStockInStore":false,"upc":"737257970304","isSearchableFlag":true,"isSKUAvailable":true,"price":{"number":18.99,"strikethrough-number":null,"validUntil":"","formatted":{"primary":"$9.99-$18.99"},"displayType":"range"},"variations":["3 Sizes"],"categories":[[{"id":"6007000","name":{"default":"Same Day Delivery"}},{"id":"6000000","name":{"default":"Featured Shops"}}],[{"id":"PERKSPOT","name":{"default":"15 OFF 75"}},{"id":"Product-Assortments","name":{"default":"PA"}}],[{"id":"ME01","name":{"default":"March Event"}},{"id":"sale","name":{"default":"Sale"}}],[{"id":"6000030","name":{"default":"Auto ship"}},{"id":"6000000","name":{"default":"Featured Shops"}}],[{"id":"SDDBOPIS","name":{"default":"Same Day Delivery In Store Pick Up"}},{"id":"sale","name":{"default":"Sale"}}],[{"id":"60000060","name":{"default":"Curbside and In Store Pickup"}},{"id":"6000000","name":{"default":"Featured Shops"}}],[{"id":"200152","name":{"default":"Litter"}},{"id":"200211","name":{"default":"Litter and Waste Disposal"}},{"id":"200000","name":{"default":"Cat"}}],[{"id":"60080122","name":{"default":"Timezone Test"}},{"id":"6000000","name":{"default":"Featured Shops"}}],[{"id":"50006501","name":{"default":"ExquisiCat"}},{"id":"5000000","name":{"default":"Featured Brands"}}],[{"id":"0824-SameDayDelivery-Sale","name":{"default":"Save on Same Day Delivery"}},{"id":"Product-Assortments","name":{"default":"PA"}}],[{"id":"0824-Same-Day-Delivery-Sale","name":{"default":"Same Day Delivery Sale"}},{"id":"Product-Assortmen