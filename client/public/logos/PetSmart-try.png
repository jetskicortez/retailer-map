301,1741,1433,2747,1572,3005,138,1402,634,2703,1589,3018,1071,601,1299,1528,1599,1662,597,654,1656,744,1640,632,383,2473,1476,3282,2427,135,2264,1096,3028,2229,656,398,1413,1104,1226,556,1192,3220,1446,1780,718,1065,2501,3214,72,332,788,2334,1128,2461,2371,2386,1551,3250,633,2358,3097,422,2504,1759,2125,2198,576,1590,1136,1076,739,1578,2327,1051,1838,2296,1040,3283,2424,2511,2233,280,1431],"size":{"solidSize":"40 Lb"},"dimensionsAndWeight":{"cartonHeight":13.69,"cartonLength":7,"cartonWeight":41.51,"cartonWidth":11.75},"package":{"height":13.69,"length":7,"weight":41.51,"width":11.75},"brand":"Arm \u0026 Hammer","customCategory":"Litter","long_description":"\u003cp\u003e\u003cb\u003eDESCRIPTION \u003c/b\u003e\u003cp\u003e ARM HAMMER Double Duty Clumping Litter eliminates both types of odors for Advanced Odor Control. Its breakthrough cat litter formula destroys urine AND feces odors on contact, and helps keep your home smelling fresh and clean with a fresh scent. ARM HAMMER Cat Litter is made with odor absorbing clay and ARM HAMMER Baking Soda in every scoop to neutralize litter box odor. Rock-solid clumps let you remove the source of odors easily and fresh scent refreshed litter every time your cat uses the kitty litter box. And that\u0026#39;s why an odor-free home starts with ARM HAMMERâ¢ clumping cat litter. Plus, with low tracking and 99.9% dust-free formula pour ARM HAMMERâ¢ kitty litter with confidence. Tough times call for value you can trust. When you\u0026#39;re feeling the price pinch, Give It the Hammer.\u003cbr\u003e \r\n\u003cp\u003e\u003cb\u003eFeatures:\u003c/b\u003e\u003cli\u003eDouble Duty Cat Litter Destroys Urine and Feces Odors Instantly \u003cli\u003e Odor Control with Powerful Moisture Activated Baking Soda Crystals Eliminates Odors on Contact \u003cli\u003e The Double Duty Formula is 99.9% Dust Free and Low Tracking \u003cli\u003e Kitty Litter featuring an easy pour and no-spill spout for less mess \u003cli\u003e Fresh Scent Refreshes Litter Every Time Your Cat Uses the Litter Box \u003cbr\u003e\r\n\u003cbr\u003e\u003cb\u003ePackage Weight:\u003c/b\u003e 40 lbs\u003cbr\u003e\r\n\u003cp\u003e\u003cb\u003eDirections:\u003c/b\u003e\u003cbr\u003eFill a clean, empty litter box with 3 - 4\" of Arm \u0026 Hammer Double Duty Advanced Odor Control Clumping Litter.\r\n\u003cbr\u003eLitter forms rock-solid clumps on contact with urine and eliminates odors; remove clumps and solid waste daily to keep the rest of the litter fresh\r\n\u003cbr\u003eAdd more Arm \u0026 Hammer Double Duty Advanced Odor Control Clumping Litter to replace what you have scooped out and maintain a depth of 3\" - 4\"; once a month, empty the entire litter box\r\n\u003cbr\u003eDispose of used litter in trash; do not flush or put in drains\r\n\u003cbr\u003eWash hands thoroughly after handling used cat litter. The manufacturer wants to remind pregnant women and those with suppressed immune systems that a parasite sometimes found in cat feces can cause toxoplasmosis.","onlineFrom":1388534400000,"onlineTo":4102444799000,"litter-features":["Clumping","Low Dust","Low Tracking","Scented"],"litter-materials":["Clay"],"litter-types":["Clay"],"customPet":["Cat"],"productAvailabilityLocations":["In Store"],"series":["Arm \u0026 Hammer Value Litter"],"avalaraTaxCode":"111","bvAverageRating":4.2,"bvReviewCount":3458,"conversionRate":85,"customBvAverageRating":4,"manufacturerName":"CHURCH AND DWIGHT CO INC","manufacturerSku":"20013903","shipToHome-isCASupported":true,"shoppingOptions-isBopisEligible":true,"shoppingOptions-isInStoreAvailable":true,"shoppingOptions-isInStoreOnly":false,"shoppingOptions-isInStorePickUp":true,"shoppingOptions-isSoldOnlineOnly":false,"customScheduledDeliveryEligible":true,"isSubscriptionEnabled":true,"isInStockInStore":true,"upc":"33200024088","isSearchableFlag":true,"isSKUAvailable":true,"price":{"number":19.99,"strikethrough-number":null,"validUntil":"","formatted":{"primary":"$11.39-$19.99"},"displayType":"range"},"variati