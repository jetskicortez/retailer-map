7,1319,3038,1277,2131,1226,2765,1882,217,1197,610,781,1654,1591,2746,3184,649,3265,1835,2331,1303,400,256,76,1756,3012,1894,1395,1891,1268,3165,2500,2705,3039,1218,2226,2183,55,1562,655,1110,2761,2350,1742,1967,376,1515,1576,2358,1056,2465,3052,3149,2435,2469,1968,3118,2278,1959,2311,2147,81,2316,2749,49,1460,1933,3023,2293,2242,192,3109,1563,2361,1670,1100,1247,1198,3046],"id":4032875,"meta":{"title":"","description":""},"masterProductID":30390,"name":"Live Crickets","primary_category_id":"500100","primary_category_name":"Food","short_description":"LARGE CRICKET                         40","images":{"large":"https://s7d2.scene7.com/is/image/PetSmart/4032875?$sclp-prd-main_large$","small":"https://s7d2.scene7.com/is/image/PetSmart/4032875?$sclp-prd-main_small$"},"personalization":{"styleOptions":{},"textLocations":{}},"merchandisingHierarchy":{"category":"Rep Bulk","class":"Rep Cricket","department":"Rep Feeder","division":"Specialty","vicePresidentId":2,"vicePresidentName":"Specialty"},"bopisCaseQty":20,"customCaseQuantity":1000,"customScheduledDeliveryEligible":true,"hasHazmatCode":false,"statesRestrictionEnabled":false,"shoppingOptions-isBopisEligible":true,"lastModifiedMillis":1773335979200,"size":{"solidSize":"Large"},"dimensionsAndWeight":{"cartonHeight":3,"cartonLength":1,"cartonWeight":0.002,"cartonWidth":3},"package":{"height":6.5,"length":0.012,"weight":0.002,"width":12},"brand":"PetSmart","customCategory":"Food","long_description":"\r\n\u003cp\u003e\u003cb\u003eDESCRIPTION \u003c/b\u003e\u003cp\u003e\r\nKeep your reptile fed and happy with this PetSmart Large Live Cricket. These crickets make a nutrient-rich meal for your pet, providing protein and other essential nutrients your pet needs to thrive. \r\n\u003cp\u003e\u003cb\u003eFeatures: \u003c/b\u003e Feeder Insect/invertebrate \u003cbr\u003e\r\n\u003cb\u003eFood Type:\u003c/b\u003e Primary Diet\u003cbr\u003e\r\n\u003cb\u003eIncludes: \u003c/b\u003e Large Cricket\u003cbr\u003e\r\n\u003cb\u003eIntended For: \u003c/b\u003e Anoles (e.g., Green, Cuban False Chameleon/Chameleolis); Lizards (e.g., Bearded Dragons, Water Dragons, Mountain Horned Dragons, Long-tailed, Curly-tailed, Plated); Chameleons (e.g., Jacksons, Veiled, Panther); Geckos (e.g., Leopard, Panther, Cave); Frogs (e.g., Pacman, Tomato, Tree); Tarantulas (e.g., Pink-toe, Curly-hair, Mexican Red Knee, Mexican Striped Knee); Scorpions (e.g., Asian Forest, Emperor)\u003cbr\u003e\r\n\u003cb\u003eFeeding Instructions: \u003c/b\u003eFor frequency refer to species care guide. Dusted with appropriate supplementation (for reptile/amphibian only). Remove within 3-4 hours if not consumed. \u003cbr\u003e\r\n\u003cp\u003e\u003cb\u003eWarning: \u003c/b\u003e Supplement live food with pellets \u0026 veggies to provide essential vitamins and nutrients.\u003cbr\u003e \r\n\u003cp\u003e\u003cb\u003eDisclaimer: \u003c/b\u003eAll feeders should be fed a high-quality diet (i.e., gut-loading) prior to feeding to maximize nutritional content to pet.","reptileFoodType":"Crickets","onlineFrom":1424217600000,"onlineTo":4102444799000,"environments":["Desert","Semi-Aquatic","Temperate"],"petType-amphibians":[""],"customPet":["Reptile"],"petType-reptiles":[""],"productAvailabilityLocations":["In Store"],"avalaraTaxCode":"EEE","bvAverageRating":4.2,"bvReviewCount":5693,"conversionRate":100,"customBvAverageRating":4,"manufacturerName":"TIMBERLINE FISHERIES CORP","manufacturerSku":"24SC1","maxOrderQty":500,"shipToHome-isCASupported":false,"shoppingOptions-isInStoreAvailable":true,"shoppingOptions-isInStoreOnly":true,"shoppingOptions-isInStoreOnlyOverride":true,"shoppingOptions-isInStorePickUp":true,"shoppingOptions-isSoldOnlineOnly":false,"isInStockInStore":true,"isSearchableFlag":true,"isSKUAvailable":true,"price":{"number":0.17,"strikethrough-number":null,"validUntil":"","formatted":{"primary":"$0.17"},"displayType":"single"},"variations":["2 Sizes"],"categories":[[{"id":"500807","name":{"default":"Chameleon"}},{"id":"500800","name":{"d