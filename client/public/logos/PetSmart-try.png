003c/b\u003e 90 oz\u003cbr\u003e\r\n\r\n\u003cp\u003e\u003cb\u003eNUTRITIONAL INFORMATION\u003c/b\u003e\u003cbr\u003e    \r\n\r\n\u003cp\u003e\u003cb\u003eIngredients:\u003c/b\u003e\u003cbr\u003e Timothy Grass Hay\u003cbr\u003e\r\n\r\n\u003cp\u003e\u003cb\u003eGuaranteed Analysis:\u003c/b\u003e\u003cbr\u003e    Crude Protein (min) 7.00%\u003cbr\u003eCrude Fat (min) 1.50%\u003cbr\u003eCrude Fiber (max) 32.00%\u003cbr\u003eMoisture (max) 15.00%\u003cbr\u003e\r\n\r\n\u003cp\u003e\u003cb\u003eFEEDING INSTRUCTIONS\u003c/b\u003e\u003cbr\u003e Place large handfuls of grass hay in your pet\u0026#39;s habitat daily.  Mix different grass hays together to enrich your pet\u0026#39;s diet.  Try all tastes and textures to discover your pet\u0026#39;s favorites.","onlineFrom":1370995200000,"onlineTo":4102444799000,"foodOuncesSizeDisplays":["16 Oz and Over"],"customHealthConsideration":["Digestive Care"],"moreWaysToShop":null,"customPet":["Small Pet"],"petType-smallPets":["Chinchilla","Guinea Pig","Rabbit"],"productAvailabilityLocations":["In Store"],"avalaraTaxCode":"EEE","bvAverageRating":3.9,"bvReviewCount":1692,"conversionRate":50,"customBvAverageRating":3,"manufacturerName":"OXBOW ANIMAL HEALTH","manufacturerSku":"12144","shipToHome-isCASupported":true,"shoppingOptions-isBopisEligible":true,"shoppingOptions-isInStoreAvailable":true,"shoppingOptions-isInStoreOnly":false,"shoppingOptions-isInStorePickUp":true,"shoppingOptions-isSoldOnlineOnly":false,"customScheduledDeliveryEligible":true,"isSubscriptionEnabled":true,"isInStockInStore":true,"upc":"744845402291","isSearchableFlag":true,"isSKUAvailable":true,"price":{"number":21.68,"strikethrough-number":25.49,"validUntil":"2035-01-01T07:00:00.000Z","formatted":{"primary":"$5.48-$50.99","strikethrough":"$6.99-$59.99"},"displayType":"range"},"variations":["5 Sizes"],"categories":[[{"id":"6007000","name":{"default":"Same Day Delivery"}},{"id":"6000000","name":{"default":"Featured Shops"}}],[{"id":"600128","name":{"default":"Rabbit"}}